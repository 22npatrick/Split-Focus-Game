script/source = "extends Control

func _ready(): 
	$AllTimeHighScoreLabel2.text = (\"All Time High Score: \" +  str(Global.high_score))

func on_button_pressed() -> void:
	get_tree().change_scene_to_file(\"res://Scene/main_1.tscn\")


func _on_button_2_pressed() -> void:
	get_tree().change_scene_to_file(\"res://Scene/settings_scene.tscn\")
"

