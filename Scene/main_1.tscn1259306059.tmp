[sub_resource type="GDScript" id="GDScript_2prf1"]
resource_name = "MainScript"
script/source = "extends Node2D
var direction: Vector2 = Vector2.LEFT 
@onready var ob1 = $Obsticle1
@onready var ob2 = $Obsticle2
var ob3
@onready var local_x = $Obsticle2.position.x
var time
@onready var array = [ob1, ob2]
var current_ob_1
var current_ob_2
@onready var ob_chosen = false
var x_level 
var y_level 
var start = true
@onready var player1 = $\"Player 1\"
@onready var player2 = $\"Player 2\"
@onready var player1_x = $\"Player 1\".position.x
@onready var player1_y = $\"Player 1\".position.y
@onready var player2_x = $\"Player 2\".position.x
@onready var player2_y = $\"Player 2\".position.y

func _ready():
	print(\"dew\")
	print(local_x)
	$\"Player 1\".position.x = player1_x
	$\"Player 1\".position.y = player1_y 
	$\"Player 2\".position.x = player2_x
	$\"Player 2\".position.y = player2_y
	if start == true:
		await get_tree().create_timer(3).timeout
		start = false
	
func _process(delta: float) -> void:
	if ob_chosen == false:
		print(\"gre\")
		current_ob_1 = array.pick_random()
		array = array.pop(current_ob_1)
		ob_chosen = true
	else:
		current_ob_1.position += direction * Global.speed * delta
	if Input.is_action_just_pressed(\"enter\"):
		get_tree().change_scene_to_file(\"res://Scene/main_1.tscn\")
		
	if player2_y > 250:
		player2.velocity.y = -100
		player2_y = $\"Player 2\".position.y
	elif player2_y < 0:
		player2.velocity.y = 100
		player2_y = $\"Player 2\".position.y
	else:
		player2.velocity.y = 0
		player2_y = $\"Player 2\".position.y
		
	if player1_y < 310:
		player1.velocity.y = 50
		player1_y = $\"Player 1\".position.y
	else:
		player1_y = $\"Player 1\".position.y
		
	if current_ob_1.position.x < 0:
		print(\"X POS REACHED\")
		ob_chosen = false
		var rng = RandomNumberGenerator.new()
		y_level = rng.randf_range(70, 500)
		x_level = local_x + rng.randf_range(0,1000)
		current_ob_1.position.x = x_level
		current_ob_1.position.y = y_level
		print( x_level, y_level)
"

[sub_resource type="RectangleShape2D" id="RectangleShape2D_2prf1"]
size = Vector2(238, 2)

[sub_resource type="GDScript" id="GDScript_5dlce"]
script/source = "extends Timer

# Called when the node enters the scene tree for the first time.
func _ready():
	Global.score = 0
	start()

func _on_timeout() -> void:
	Global.score += 1
	Global.sec += 1
	print(\"new score \" + str(Global.score))
	$\"../Label\".text = (\"Score: \" + str(Global.score))
	if (Global.high_score) <= (Global.score):
		print(\"PRINT\")
		Global.high_score = Global.score
		print(Global.high_score)
	else:
		print(\"fre\")
	if Global.speed < Global.max_speed:
		Global.speed = Global.speed * Global.speed_increase
	else:
		print(\"MAX\")
"

