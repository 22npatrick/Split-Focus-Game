[gd_scene format=3 uid="uid://cewpb7ye1k0yl"]

[sub_resource type="GDScript" id="GDScript_dcvh0"]
script/source = "extends Control

func _ready():
	$AllTimeHighScoreLabel1.text = (\"Run High Score: \" +  str(Global.score)) 
	$HighScoreLabel1.text = (\"All Time High Score: \" +  str(Global.high_score))


func _on_button_pressed() -> void:
	get_tree().change_scene_to_file(\"res://Scene/main_1.tscn\")


func _on_button_2_pressed() -> void:
	get_tree().change_scene_to_file(\"res://Scene/start_game_scene.tscn\")
"

