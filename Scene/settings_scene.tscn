[gd_scene format=3 uid="uid://oee7qwqy5no2"]

[sub_resource type="GDScript" id="GDScript_dn512"]
script/source = "extends Control

func _ready() -> void:
	$VBoxContainer/CheckBox1.button_pressed = Global.game_diff[0]
	$VBoxContainer/CheckBox2.button_pressed = Global.game_diff[1]
	$VBoxContainer/CheckBox3.button_pressed = Global.game_diff[2]
	
func _on_button_pressed() -> void:
	get_tree().change_scene_to_file(\"res://Scene/start_game_scene.tscn\")

func _on_check_box_1_pressed() -> void:
	Global.speed_increase = 1.0075
	Global.max_speed = 500.0
	Global.game_diff = [true, false, false]

func _on_check_box_2_pressed() -> void:
	Global.speed_increase = 1.0125
	Global.max_speed = 750.0
	Global.game_diff = [false, true, false]

func _on_check_box_3_pressed() -> void:
	Global.speed_increase = 1.025
	Global.max_speed = 1000.0
	Global.game_diff = [false, false, true]
"

